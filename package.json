{
  "name": "palate",
  "main": "main.ts",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf android ios .expo node_modules",
    "ios": "expo run:ios",
    "mobile:prepare": "expo prebuild --clean",
    "mobile:dev": "expo run:ios --device",
    "mobile:submit": "eas build --platform ios --auto-submit --non-interactive",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix . && oxfmt --write .",
    "android": "expo run:android"
  },
  "dependencies": {
    "@expo/dom-webview": "~57.0.0",
    "@expo/metro-runtime": "~57.0.3",
    "@expo/ui": "~57.0.3",
    "@expo/vector-icons": "15.1.1",
    "@react-native-firebase/analytics": "^25.1.0",
    "@react-native-firebase/app": "^25.1.0",
    "@shopify/flash-list": "2.3.2",
    "@shopify/react-native-skia": "2.6.9",
    "@tanstack/query-core": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "burnt": "^0.13.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "expo": "^57.0.2",
    "expo-asset": "~57.0.3",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-calendar": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.2",
    "expo-maps": "~57.0.0",
    "expo-media-library": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-sharing": "~57.0.2",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-video": "~57.0.0",
    "geokdbush": "^2.1.0",
    "kdbush": "^4.1.0",
    "lodash-es": "^4.18.1",
    "p-map": "^7.0.5",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tz-lookup": "^6.1.25",
    "uniwind": "^1.10.0",
    "zustand": "^5.0.14"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/flash-list",
        "@shopify/react-native-skia",
        "react-native-reanimated",
        "react-native-worklets"
      ]
    }
  },
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.0",
    "@types/react": "~19.2.17",
    "@types/tz-lookup": "^6.1.2",
    "@typescript/native-preview": "7.0.0-dev.20260704.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "knip": "^6.24.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "~6.0.3"
  }
}
