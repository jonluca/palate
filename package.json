{
  "name": "palate",
  "main": "main.ts",
  "version": "1.0.0",
  "scripts": {
    "server:dev": "vite --config vite.server.config.ts",
    "server:start": "node dist/server/index.mjs",
    "build": "vite build --config vite.server.config.ts",
    "start": "node dist/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android ios .expo node_modules",
    "ios": "expo run:ios",
    "mobile:prepare": "expo prebuild --clean",
    "mobile:dev": "expo run:ios --device",
    "mobile:submit": "eas build --platform ios --auto-submit --non-interactive",
    "web": "expo start --web",
    "auth:generate": "better-auth generate --config server/auth.ts --output server/db/schema/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:canonical-restaurants": "tsx scripts/seed-canonical-restaurants.ts",
    "seed:demo-social": "tsx scripts/seed-demo-social.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix . && oxfmt --write .",
    "android": "expo run:android"
  },
